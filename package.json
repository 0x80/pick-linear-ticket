{
  "name": "pick-linear-ticket",
  "version": "0.1.0",
  "description": "CLI that picks the next eligible Linear ticket from a team's backlog.",
  "keywords": [
    "backlog",
    "branch-name",
    "cli",
    "linear",
    "ticket"
  ],
  "homepage": "https://github.com/0x80/pick-linear-ticket",
  "bugs": {
    "url": "https://github.com/0x80/pick-linear-ticket/issues"
  },
  "license": "MIT",
  "author": "Thijs Koerselman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x80/pick-linear-ticket.git"
  },
  "bin": "./dist/cli.mjs",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint -c .oxlintrc.json --import-plugin --type-aware",
    "pick": "node ./src/cli.ts",
    "prepare": "tsdown && (lefthook install 2>/dev/null || true)",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "execa": "^9.6.0",
    "meow": "^13.2.0"
  },
  "devDependencies": {
    "@codecompose/typescript-config": "^3.2.0",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260519.1",
    "lefthook": "^2.1.8",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.16.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.2"
}
